APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000     # Port mập với APP_PORT bên dưới

APP_PORT=8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel-react-messenger
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret       # Dùng cho MySQL container (MYSQL_ROOT_PASSWORD)
FORWARD_DB_PORT=3306              # Port MySQL expose ra host để dung Laragon/TablePlus

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null


# ─── Reverb (WebSocket) ─────────────────────────────────────────────
# REVERB_HOST=reverb   → PHP app (server-side) kết nối qua Docker network nội bộ
# VITE_REVERB_HOST=localhost → Browser kết nối qua port mapping ra ngoài
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
FORWARD_REDIS_PORT=6379


MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_UI_PORT=8025              # Web UI của Mailpit


GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_PREMIUM_PRICE_CENTS=499
PAYPAL_PREMIUM_CURRENCY=USD

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=messenger
AWS_ENDPOINT=http://minio:9000    # MinIO endpoint (nội bộ Docker)
AWS_USE_PATH_STYLE_ENDPOINT=true  # Bắt buộc với MinIO
MINIO_PORT=9000                   # S3 API port
MINIO_CONSOLE_PORT=9001           # Web console: http://localhost:9001

REVERB_APP_ID=my-app-id
REVERB_APP_KEY=my-app-key
REVERB_APP_SECRET=my-app-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost         # Browser connect đến localhost (port-mapped)
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
